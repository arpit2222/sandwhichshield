# SandwichShield Environment Variables

# RPC Endpoint for Mantle (Testnet or Mainnet)
MANTLE_RPC_URL="https://rpc.sepolia.mantle.xyz"

# Your wallet private key (starts without 0x)
PRIVATE_KEY="YOUR_PRIVATE_KEY_HERE"

# Deployed Smart Contract Address (fill after running deploy.ts)
CONTRACT_ADDRESS="YOUR_DEPLOYED_CONTRACT_ADDRESS"

# Explorer API Key for Contract Verification
MANTLE_EXPLORER_API_KEY="YOUR_MANTLE_API_KEY"

# Telegram Bot Token (Get from @BotFather)
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"

# Telegram Chat ID to send alerts to
TELEGRAM_CHAT_ID="YOUR_TELEGRAM_CHAT_ID"
